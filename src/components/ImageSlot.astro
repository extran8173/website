---
// 이미지 슬롯 — 실제 자산이 있으면 최적화 이미지/영상으로, 없으면 중립 자리표시 패널로 렌더.
// 드롭인 규칙: src/assets/site/{슬롯ID}.{확장자} 파일을 넣으면 자동 전환된다. (README 참조)
// 기준: 사업장·작업 사진 AI 생성/스톡 금지(CLAUDE.md) → 확보 전까지 빈 슬롯 유지.
import { Image } from 'astro:assets';

interface Props {
  id: string; // IMG-0xx / VID-0xx (= 파일명)
  label: string; // 자리표시에 보이는 컷 설명 + 실제 렌더 시 alt 기본값
  alt?: string; // 실제 이미지 alt(SEO). 생략 시 label 사용, 빈 문자열이면 장식용
  ratio?: string; // CSS aspect-ratio, 기본 16/9
  tone?: 'light' | 'dark';
  kind?: 'image' | 'video'; // 영상 자리 표기용
  cover?: boolean; // 부모를 꽉 채우는 배경(풀블리드 히어로 등)
}
const { id, label, alt, ratio = '16 / 9', tone = 'light', kind = 'image', cover = false } = Astro.props;

// 실제 자산 자동 탐지 (빌드 타임). 파일이 없으면 빈 객체 → 자리표시로 폴백.
const imageAssets = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/site/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true },
);
const videoAssets = import.meta.glob<string>(
  '/src/assets/site/*.{mp4,webm,MP4,WEBM}',
  { eager: true, query: '?url', import: 'default' },
);

const stem = (p: string) => (p.split('/').pop() ?? '').replace(/\.[^.]+$/, '');
const imageEntry = Object.entries(imageAssets).find(([p]) => stem(p) === id)?.[1];
const videoUrl = Object.entries(videoAssets).find(([p]) => stem(p) === id)?.[1];

const hasVideo = kind === 'video' && !!videoUrl;
const hasImage = !hasVideo && !!imageEntry;
const altText = alt ?? label;
const note = kind === 'video' ? '영상 위치 · 실제 클립으로 교체 예정' : '사진 위치 · 실제 컷으로 교체 예정';
---

{hasVideo ? (
  <video
    class:list={['img-media', { cover }]}
    style={cover ? undefined : `aspect-ratio:${ratio}`}
    src={videoUrl}
    autoplay
    muted
    loop
    playsinline
    aria-label={altText || undefined}
  ></video>
) : hasImage ? (
  <Image
    class:list={['img-media', { cover }]}
    style={cover ? undefined : `aspect-ratio:${ratio}`}
    src={imageEntry!.default}
    alt={altText}
    widths={cover ? [768, 1280, 1920] : [480, 800, 1200]}
    sizes={cover ? '100vw' : '(min-width: 835px) 50vw, 100vw'}
  />
) : (
  <div
    class:list={['img-slot', tone, kind, { cover }]}
    style={cover ? undefined : `aspect-ratio:${ratio}`}
    role="img"
    aria-label={label}
  >
    <span class="img-slot-id">{kind === 'video' ? '▶ ' : ''}{id}</span>
    <span class="img-slot-label">{label}</span>
    <span class="img-slot-note">{note}</span>
  </div>
)}

<style>
  /* 실제 자산: 슬롯을 꽉 채우고 지정 비율로 크롭 */
  .img-media {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--rounded-lg);
  }
  .img-media.cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
  }

  /* 자리표시 패널 */
  .img-slot {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border-radius: var(--rounded-lg);
    padding: var(--space-lg);
    text-align: center;
  }
  .img-slot.light {
    background: var(--color-canvas-parchment);
    border: 1px dashed var(--color-hairline);
    color: var(--color-ink-muted-48);
  }
  .img-slot.dark {
    background: var(--color-surface-tile-2);
    border: 1px dashed #4a4a4d;
    color: var(--color-body-muted);
  }
  /* 풀블리드 배경(히어로 등): 부모를 꽉 채운다 */
  .img-slot.cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
  }
  /* 영상 자리: 라운드 유지하되 재생 뉘앙스만 살짝 */
  .img-slot.video.light { background: var(--color-surface-pearl); }
  .img-slot-id { font-size: 12px; letter-spacing: 0.04em; opacity: 0.8; }
  .img-slot-label { font-size: 15px; font-weight: 600; }
  .img-slot-note { font-size: 12px; opacity: 0.7; }
</style>
