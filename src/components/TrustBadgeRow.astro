---
// trust-badge-row — 경력·ISO·A/S 배지 (configurator-option-chip 규격, 텍스트 주인공)
// 기준: 03_common_ui §5 · 04_trust_sections · DESIGN-motorrepair §4
import { business } from '../data/business.ts';
const badges = [
  `경력 ${business.careerYears}년`,
  business.certifications.join(' · '),
  ...business.awards,
  `부품 A/S ${business.warranty.period} / ${business.warranty.distance}`,
];
---

<ul class="trust-badges">
  {badges.map((b) => <li class="trust-badge t-caption">{b}</li>)}
</ul>

<style>
  .trust-badges {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .trust-badge {
    border: 1px solid var(--color-hairline);
    border-radius: var(--rounded-pill);
    padding: 8px 16px;
    color: var(--color-ink-muted-80);
    background: var(--color-canvas);
    white-space: nowrap;
  }
</style>
