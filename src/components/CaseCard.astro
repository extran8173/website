---
// case-card — 사례 카드 (store-utility-card 규격: hairline · 18px · 24px 패딩)
// 사용: 사례 목록 · recent-cases · 관련 사례. 명세: 03_common_ui §5 · page_cases
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'cases'>;
}
const { entry } = Astro.props;
const d = entry.data;
const href = `/cases/${d.slug ?? entry.id.replace(/\/index$/, '')}/`;
const dateText = d.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a class="case-card" href={href}>
  <div class="case-card-thumb">
    <Image src={d.thumbnail} alt={`${d.region} ${d.brand} 정비 사례 ${d.car_model}`} widths={[400, 800]} sizes="(max-width: 640px) 100vw, 400px" loading="lazy" />
  </div>
  <h3 class="case-card-title t-body-strong">{d.title}</h3>
  <p class="case-card-result t-caption">{d.result}</p>
  <time class="case-card-date t-caption" datetime={d.date.toISOString()}>{dateText}</time>
</a>

<style>
  .case-card {
    display: block;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--rounded-lg);
    padding: var(--space-lg);
    color: var(--color-ink);
    transition: transform 0.12s ease;
  }
  .case-card:active { transform: scale(0.99); }
  .case-card-thumb {
    border-radius: var(--rounded-sm);
    overflow: hidden;
    margin-bottom: var(--space-sm);
    aspect-ratio: 3 / 2;
  }
  .case-card-thumb :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .case-card-title { margin: 0 0 6px; color: var(--color-ink); }
  .case-card-result { margin: 0 0 12px; color: var(--color-ink-muted-80); }
  .case-card-date { color: var(--color-ink-muted-48); }
</style>
