---
// 404 — 정적 사이트 커스텀 오류 페이지. Cloudflare Pages 가 dist/404.html 을 404 상태로 서빙.
import BaseLayout from '../layouts/BaseLayout.astro';
import { navItems, cta } from '../data/business.ts';

const title = '페이지를 찾을 수 없습니다 | 모터리페어';
const description = '요청하신 페이지가 없거나 주소가 바뀌었습니다.';
---

<BaseLayout title={title} description={description} path="/404">
  <meta slot="head" name="robots" content="noindex" />

  <section class="nf">
    <div class="container">
      <p class="nf-code t-latin">404</p>
      <h1 class="t-display-md">찾으시는 페이지가 없습니다</h1>
      <p class="nf-body t-body">주소가 바뀌었거나 삭제된 페이지일 수 있습니다. 아래에서 원하시는 곳으로 이동해 주세요.</p>

      <nav class="nf-links" aria-label="주요 페이지">
        {navItems.map((item) => (
          <a href={item.href} class="nf-link t-body">{item.label}</a>
        ))}
      </nav>

      <div class="nf-cta">
        <a href={cta.callHref} class="btn btn-call">{cta.callLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { background: var(--color-canvas); padding-block: var(--space-section); }
  .nf-code { color: var(--color-primary); font-size: 56px; font-weight: 600; margin: 0 0 var(--space-sm); }
  .nf h1 { color: var(--color-ink); margin: 0 0 var(--space-md); }
  .nf-body { color: var(--color-ink-muted-80); max-width: 48ch; margin: 0 0 var(--space-xl); }
  .nf-links { display: flex; flex-wrap: wrap; gap: var(--space-lg); margin-bottom: var(--space-xl); }
  .nf-link { color: var(--color-primary); }
  .nf-cta { display: flex; }
</style>
