---
// 메인 — 확정본: docs/기획/page_main.md
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBadgeRow from '../components/TrustBadgeRow.astro';
import RecentCases from '../components/RecentCases.astro';
import CtaSection from '../components/CtaSection.astro';
import ImageSlot from '../components/ImageSlot.astro';
import { business, cta } from '../data/business.ts';

const title = '동탄 수입차 전문 정비 | 모터리페어';
const description =
  '동탄·화성·오산·평택 수입차 정비. 엔진오일·미션오일 등 소모품 교환을 제조사 규격대로, 경고등·고장은 BMW·벤츠·아우디·포르쉐 전용 진단기로 진단합니다. 부품 A/S 1년/2만km.';

// 정기 점검·소모품 교환 — 대표 정비(요약, 상세는 /services/#maintenance)
const maintenanceGroups = [
  { title: '오일류', items: '엔진오일 · 미션오일 · 디퍼렌셜오일 · 트랜스퍼케이스오일' },
  { title: '유체 · 냉각', items: '브레이크액 · 냉각수 · 에어컨 냉매' },
  { title: '필터류', items: '에어컨 필터 · 연료 필터' },
  { title: '브레이크', items: '브레이크 패드 · 브레이크 로터' },
  { title: '벨트 · 펌프', items: '구동벨트 · 타이밍벨트 · 워터펌프 · 써머스탯' },
];

// 증상 진입 블록 (고장 진단)
const symptoms = [
  { text: '경고등이 떴어요', link: '진단', href: '/services/#diagnosis' },
  { text: '주행 중 소음이 나요', link: '브레이크·서스펜션', href: '/services/#brake-suspension' },
  { text: '에어컨이 안 나와요', link: '냉·난방', href: '/services/#hvac' },
  { text: '냉각수가 부족하다고 떠요', link: '냉·난방', href: '/services/#hvac' },
  { text: '오일 교환 시기가 됐어요', link: '소모품 교환', href: '/services/#maintenance' },
];

// §7 후기 (04_trust_sections §3 — 캡처 원문 기준)
const reviews = [
  { quote: '간단한 작업이라도 하나하나 꼼꼼히 체크해 주셔서 항상 믿고 차를 맡길 수 있어요.', source: '구글 리뷰' },
  { quote: '직접 진단에 신경을 많이 쓰는 곳이에요. 자세히 설명해 주셔서 좋았습니다.', source: '구글 리뷰, BMW 320d 차주' },
  { quote: '정비소 많이 다녀봤는데 진짜 무언가 다른 곳입니다.', source: '구글 리뷰' },
];

// §8 FAQ 3문항
const faqs = [
  {
    q: '사설 정비소에서 수리하면 제조사 보증이 깨지나요?',
    a: '보증 기간 중인 차량은 입고 시 미리 알려주세요. 보증 수리 대상인 항목은 공식 서비스센터 이용이 유리할 수 있어 사전에 안내해 드리며, 모터리페어에서 교환한 부품은 제조사 기준과 동일하게 1년/2만km A/S를 적용합니다.',
  },
  {
    q: '당일 정비도 가능한가요?',
    a: '엔진오일 등 오일류와 소모품 교환 같은 메인터넌스 정비는 당일 가능합니다. 진단이 필요한 증상이나 중정비는 전화로 증상을 말씀해 주시면 소요 일정을 미리 안내해 드립니다.',
  },
  {
    q: '수리하는 동안 차가 없으면 어떻게 하나요?',
    a: '대차 2대를 운용하고 있습니다. 예약 시 말씀해 주시면 일정에 맞춰 준비해 드립니다.',
  },
];
---

<BaseLayout title={title} description={description} path="/">
  {/* [1] 히어로 — IMG-001 사업장 정면(간판) 풀블리드 배경 + 하단 스크림. VID-001로 교체 가능 */}
  <section class="hero">
    <ImageSlot
      id="IMG-001"
      label="사업장 정면(간판)·정비 베이 3칸 · 풀블리드 배경"
      alt="동탄 수입차 정비소 모터리페어 외관"
      tone="dark"
      cover={true}
    />
    <div class="hero-scrim"></div>
    <div class="container hero-inner">
      <p class="hero-eyebrow t-caption-strong">동탄·화성·오산·평택 수입차 전문</p>
      <h1 class="t-hero-display">동탄 수입차 전문 정비</h1>
      <p class="hero-sub t-lead">정기 점검·소모품 교환부터 고장 진단까지, 과정을 사진으로 보여드립니다.</p>
      <div class="hero-cta">
        <a href={cta.callHref} class="btn btn-call btn-hero">{cta.callLabel}</a>
        <a href={cta.naverHref} target="_blank" rel="noopener" class="btn btn-naver btn-hero">{cta.naverLabel}</a>
      </div>
    </div>
  </section>

  {/* [2] 신뢰 배지 */}
  <section class="badges-band">
    <div class="container"><TrustBadgeRow /></div>
  </section>

  {/* [3] 소개 한 문단 — GEO 엔티티 선언 · 50/50 분할 (글 + 작업 컷) */}
  <section class="intro">
    <div class="container split">
      <div class="split-text">
        <h2 class="t-display-md">모터리페어는 이런 곳입니다</h2>
        <p class="intro-body t-body">
          모터리페어는 경기 화성 동탄에서 BMW·벤츠·아우디·폭스바겐·미니·포르쉐를 정비하는 수입차 전문 정비소입니다.
          엔진오일·미션오일 등 교환주기가 정해진 소모품 정비를 차종별 제조사 규격에 맞춰 진행하고, 원인 모를 증상은 ISTA+·Xentry·ODIS·VCDS·PIWIS 등 브랜드 전용 진단기로 진단합니다.
          점검부터 출고까지 모든 과정을 사진으로 기록해 보여드리며, 서비스센터와 엔진 전문회사에서 20년 넘게 현장을 지켜온 전문 정비사가 고객님의 차량 고민을 함께 나누며, 기본에 충실하게 차근차근 정비합니다.
        </p>
        <p class="intro-channel t-body">
          모터리페어는 [장용석의 내차를 부탁해] 동탄신도시점을 운영하고 있으며, 실제 수리 과정을 유튜브 영상으로 공개합니다.
        </p>
      </div>
      <div class="split-media">
        <ImageSlot
          id="IMG-015"
          label="대표·직원이 실제 정비하는 작업 컷 (얼굴 또는 손)"
          alt="동탄 수입차 정비소 정비 작업 모습"
          ratio="4 / 5"
        />
      </div>
    </div>
    {/* 채널 대표 영상 — 페이지 내 재생 (벤츠 CLS 350D 수리 과정 풀영상) */}
    <div class="container">
      <div class="intro-video">
        <iframe
          src="https://www.youtube-nocookie.com/embed/h4pLzE6pA10"
          title="중고차 묻따구매 벤츠 CLS 350D 수리 과정 풀영상 — 장용석의 내차를 부탁해"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  {/* [4] 정기 점검·소모품 교환 — 대표 정비 · 50/50 분할(사진 + 글) 후 칩 그리드 */}
  <section class="maint-band">
    <div class="container split split--reverse">
      <div class="split-media">
        <ImageSlot
          id="IMG-022"
          label="소모품 교환 작업 컷 (엔진룸 점검)"
          alt="동탄 수입차 정비소 엔진룸 점검 작업"
          ratio="4 / 5"
        />
      </div>
      <div class="split-text">
        <p class="maint-eyebrow t-caption-strong">정기 점검 · 소모품 교환</p>
        <h2 class="t-display-md">정비의 대부분은 소모품 교환입니다</h2>
        <p class="maint-band-body t-body">
          엔진오일·미션오일부터 브레이크·냉각수, 벨트·워터펌프까지 — 교환주기가 정해진 소모품을 차종별 제조사 규격에 맞춰 교환합니다. 교환 전 상태를 사진으로 보여드리고, 대부분 당일 정비로 진행됩니다.
        </p>
      </div>
    </div>
    <div class="container">
      <ul class="maint-chip-grid">
        {maintenanceGroups.map((g) => (
          <li class="maint-chip">
            <span class="maint-chip-title t-body-strong">{g.title}</span>
            <span class="maint-chip-items t-caption">{g.items}</span>
          </li>
        ))}
      </ul>
      <a href="/services/#maintenance" class="maint-more t-body">소모품 교환 항목 자세히 보기 →</a>
    </div>
  </section>

  {/* [5] 증상 진입 블록 — 고장 진단 */}
  <section class="symptoms">
    <div class="container">
      <h2 class="t-display-md">이런 증상이신가요?</h2>
      <ul class="symptom-grid">
        {symptoms.map((s) => (
          <li>
            <a href={s.href} class="symptom-card">
              <span class="symptom-text t-body-strong">“{s.text}”</span>
              <span class="symptom-link t-caption">→ {s.link}</span>
            </a>
          </li>
        ))}
      </ul>
      <a href={cta.callHref} class="symptom-more t-body">다른 증상도 전화로 말씀해 주세요 →</a>
    </div>
  </section>

  {/* [6] 진단 장비 티저 — 다크 타일 · 50/50 분할(글 + 진단기 실물 사진) */}
  <section class="equip-teaser">
    <div class="container split">
      <div class="split-text">
        <h2 class="t-display-md">장비가 진단의 절반입니다</h2>
        <p class="equip-teaser-body t-body">
          BMW ISTA+, 벤츠 Xentry, 아우디 ODIS, VCDS, 포르쉐 PIWIS. 브랜드가 쓰는 진단기를 그대로 갖추고, Picoscope로 전기 신호까지 계측합니다.
        </p>
        <a href="/equipment/" class="equip-teaser-link t-body">어떤 장비로 진단하는지 보기 →</a>
      </div>
      <div class="split-media split-media--stack">
        <ImageSlot
          id="IMG-002"
          label="브랜드 전용 진단 노트북 세트 (ISTA·Xentry·ODIS·PIWIS)"
          alt="수입차 브랜드 전용 진단기 ISTA Xentry ODIS PIWIS"
          ratio="16 / 10"
          tone="dark"
        />
        {/* VID-003 — 자체 촬영 클립 확보 전까지 YouTube 임베드로 사이트 내 재생 (PicoScope 공식 소개 영상) */}
        <div class="video-embed">
          <iframe
            src="https://www.youtube-nocookie.com/embed/5L1g5f6iJ7s"
            title="Picoscope 진단 영상"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  {/* [6] 최근 정비 사례 */}
  <RecentCases
    heading="최근 정비 기록"
    sub="모든 정비는 차종·증상·원인·수리·결과를 사진과 함께 기록합니다."
    tone="canvas"
  />

  {/* [7] 후기 */}
  <section class="reviews">
    <div class="container">
      <h2 class="t-display-md">차주분들이 남긴 말</h2>
      <p class="reviews-rating t-body-strong">구글 평점 ★4.7</p>
      <div class="reviews-grid">
        {reviews.map((r) => (
          <blockquote class="review-card">
            <p class="review-quote t-body">“{r.quote}”</p>
            <cite class="review-source t-caption">— {r.source}</cite>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  {/* [8] FAQ 3문항 */}
  <section class="faq">
    <div class="container">
      <h2 class="t-display-md">자주 묻는 질문</h2>
      {faqs.map((f) => (
        <div class="faq-item">
          <h3 class="t-body-strong">{f.q}</h3>
          <p class="t-body">{f.a}</p>
        </div>
      ))}
    </div>
  </section>

  {/* [9] 최종 CTA */}
  <CtaSection
    text="증상만 말씀하셔도 됩니다. 원인은 저희가 찾겠습니다."
    caption={business.hours.displayLines.join(' · ')}
  />
</BaseLayout>

<style>
  /* [1] 히어로 — IMG-001 풀블리드 배경 + 하단 스크림 */
  .hero {
    position: relative;
    color: var(--color-on-dark);
    background: var(--color-surface-tile-1);
    min-height: 78vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  /* 하단 40% 검정 단색 스크림 (그라디언트 장식 아님 — 기능적 명도 확보, §3) */
  .hero-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.30) 34%, rgba(0,0,0,0) 60%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    display: flex; flex-direction: column; align-items: flex-start; gap: 18px;
    padding-block: 56px;
  }
  .hero-eyebrow { color: var(--color-body-muted); margin: 0; letter-spacing: 0.04em; }
  .hero :global(.t-hero-display) { color: var(--color-on-dark); }
  .hero-sub { color: #eaeaea; margin: 0; max-width: 40ch; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px; }
  .hero .btn-naver { color: var(--color-on-dark); border-color: var(--color-on-dark); }

  /* 공통 50/50 분할 (사진 중심 리듬) */
  .split { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); align-items: center; }
  .split-text { min-width: 0; }
  .split-media { min-width: 0; }
  .split-media--stack { display: flex; flex-direction: column; gap: var(--space-md); }
  @media (min-width: 835px) {
    .split { grid-template-columns: 1fr 1fr; gap: var(--space-xxl); }
    .split--reverse .split-media { order: -1; }
  }

  .badges-band { background: var(--color-canvas); padding-block: var(--space-xl); }

  .intro { background: var(--color-canvas-parchment); padding-block: var(--space-section); }
  .intro h2 { color: var(--color-ink); margin: 0 0 var(--space-lg); }
  .intro-body { color: var(--color-ink-muted-80); max-width: 68ch; margin: 0; }
  .intro-channel { color: var(--color-ink-muted-80); max-width: 68ch; margin: var(--space-md) 0 0; }
  /* 채널 대표 영상 — 페이지 내 재생 */
  .intro-video {
    aspect-ratio: 16 / 9;
    border-radius: var(--rounded-lg);
    overflow: hidden;
    background: var(--color-surface-tile-2);
    margin-top: var(--space-xl);
  }
  .intro-video iframe { display: block; width: 100%; height: 100%; border: 0; }

  /* [4] 정기 점검·소모품 교환 — 대표 정비 (canvas) */
  .maint-band { background: var(--color-canvas); padding-block: var(--space-section); }
  .maint-band .split { margin-bottom: var(--space-xxl); }
  .maint-eyebrow { display: block; color: var(--color-primary); margin: 0 0 8px; letter-spacing: 0.02em; }
  .maint-band h2 { color: var(--color-ink); margin: 0 0 var(--space-md); }
  .maint-band-body { color: var(--color-ink-muted-80); margin: 0; }
  .maint-chip-grid {
    list-style: none; margin: 0 0 var(--space-xl); padding: 0;
    display: grid; grid-template-columns: 1fr; gap: var(--space-sm);
  }
  .maint-chip {
    display: flex; flex-direction: column; gap: 4px;
    border: 1px solid var(--color-hairline); border-radius: var(--rounded-lg); padding: var(--space-lg);
  }
  .maint-chip-title { color: var(--color-primary); }
  .maint-chip-items { color: var(--color-ink-muted-80); }
  .maint-more { display: inline-block; color: var(--color-primary); }

  /* [5] 증상 진입 (parchment — 교대 리듬) */
  .symptoms { background: var(--color-canvas-parchment); padding-block: var(--space-section); }
  .symptoms h2 { color: var(--color-ink); margin: 0 0 var(--space-xl); }
  .symptom-grid {
    list-style: none; margin: 0 0 var(--space-lg); padding: 0;
    display: grid; grid-template-columns: 1fr; gap: var(--space-sm);
  }
  .symptom-card {
    display: flex; flex-direction: column; gap: 6px;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline); border-radius: var(--rounded-lg);
    padding: var(--space-lg); color: var(--color-ink); transition: transform 0.12s ease;
  }
  .symptom-card:active { transform: scale(0.99); }
  .symptom-link { color: var(--color-primary); }
  .symptom-more { display: inline-block; color: var(--color-primary); }

  .equip-teaser { background: var(--color-surface-tile-1); color: var(--color-on-dark); padding-block: var(--space-section); }
  .equip-teaser h2 { color: var(--color-on-dark); margin: 0 0 var(--space-lg); }
  .equip-teaser-body { color: var(--color-body-muted); max-width: 60ch; margin: 0 0 var(--space-lg); }
  .equip-teaser-link { color: var(--color-primary-on-dark); }
  /* VID-003 자리 — YouTube 사이트 내 재생 (자체 클립 확보 시 영상으로 교체) */
  .video-embed {
    aspect-ratio: 16 / 9;
    border-radius: var(--rounded-lg);
    overflow: hidden;
    background: var(--color-surface-tile-2);
  }
  .video-embed iframe { display: block; width: 100%; height: 100%; border: 0; }

  .reviews { background: var(--color-canvas-parchment); padding-block: var(--space-section); }
  .reviews h2 { color: var(--color-ink); margin: 0 0 var(--space-sm); }
  .reviews-rating { color: var(--color-ink); margin: 0 0 var(--space-xl); }
  .reviews-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); }
  .review-card {
    margin: 0; background: var(--color-canvas); border: 1px solid var(--color-hairline);
